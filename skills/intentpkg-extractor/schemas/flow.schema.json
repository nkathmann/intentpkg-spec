{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://intentpkg.dev/schemas/flow.schema.json",
  "title": "ui/flows/*.flow.yaml",
  "type": "object",
  "required": [
    "id",
    "steps"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "viewport": {
      "type": "string"
    },
    "fixture": {
      "type": "string"
    },
    "auth": {
      "oneOf": [
        {
          "const": "none"
        },
        {
          "type": "object",
          "required": [
            "principal"
          ],
          "properties": {
            "principal": {
              "type": "string"
            }
          },
          "additionalProperties": false
        }
      ]
    },
    "setup": {
      "type": "array"
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "minProperties": 1,
        "maxProperties": 1,
        "properties": {
          "goto": {
            "type": "string"
          },
          "click": {
            "type": "string"
          },
          "hover": {
            "type": "string"
          },
          "press": {
            "type": "string"
          },
          "wait_for": {
            "type": "string"
          },
          "fill": {
            "type": "object",
            "required": [
              "anchor",
              "value"
            ],
            "properties": {
              "anchor": {
                "type": "string"
              },
              "value": {
                "type": "string"
              }
            },
            "additionalProperties": false
          },
          "select": {
            "type": "object",
            "required": [
              "anchor",
              "value"
            ],
            "properties": {
              "anchor": {
                "type": "string"
              },
              "value": {
                "type": "string"
              }
            },
            "additionalProperties": false
          },
          "http": {
            "type": "object",
            "required": [
              "path"
            ],
            "properties": {
              "method": {
                "type": "string"
              },
              "path": {
                "type": "string"
              }
            },
            "additionalProperties": false
          },
          "expect": {
            "type": "object",
            "properties": {
              "anchor": {
                "type": "string"
              },
              "url_path": {
                "type": "string"
              },
              "visible": {
                "type": "boolean"
              },
              "copy": {
                "type": "string"
              },
              "contains_text": {
                "type": "string"
              },
              "count_min": {
                "type": "integer"
              },
              "text_not_empty": {
                "type": "boolean"
              },
              "value": {
                "type": "string"
              }
            },
            "additionalProperties": false
          },
          "expect_db": {
            "type": "object",
            "properties": {
              "delta": {
                "type": "object",
                "required": [
                  "query",
                  "equals"
                ],
                "additionalProperties": false,
                "properties": {
                  "query": {
                    "type": "string"
                  },
                  "equals": {
                    "type": "number"
                  }
                }
              },
              "equals": {
                "type": "object",
                "required": [
                  "query",
                  "value"
                ],
                "additionalProperties": false,
                "properties": {
                  "query": {
                    "type": "string"
                  },
                  "value": {}
                }
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    },
    "strictness": {
      "type": "object",
      "properties": {
        "no_unexpected_dialogs": {
          "type": "boolean"
        },
        "max_extra_steps": {
          "type": "integer"
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}