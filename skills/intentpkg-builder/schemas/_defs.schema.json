{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://intentpkg.dev/schemas/_defs.schema.json",
  "title": "Shared definitions",
  "$defs": {
    "provenance": {
      "type": "object",
      "required": ["kind"],
      "properties": {
        "kind": { "enum": ["declared", "inferred", "observed"] },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "evidence": { "type": "array", "items": { "type": "string" } },
        "note": { "type": "string" },
        "trace_id": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "expect": {
      "type": "object",
      "properties": {
        "status": { "type": "integer", "minimum": 100, "maximum": 599 },
        "body_contains": {},
        "body_not_contains": {
          "anyOf": [ { "type": "string" }, { "type": "array", "items": { "type": "string" } } ]
        },
        "body_schema": { "type": "object" },
        "body_schema_ref": { "type": "string" },
        "headers_contain": { "type": "object" },
        "side_effects": { "type": "array", "items": { "type": "string" } },
        "db_checks": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["query"],
            "properties": {
              "name": { "type": "string" },
              "store": { "type": "string" },
              "query": { "type": "string" },
              "equals": { "type": ["string", "number"] },
              "delta": { "type": "number" }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },
    "request": {
      "type": "object",
      "required": ["method", "path"],
      "properties": {
        "method": { "enum": ["GET", "POST", "PUT", "PATCH", "DELETE", "OPTIONS", "HEAD"] },
        "path": { "type": "string" },
        "headers": { "type": "object", "additionalProperties": { "type": "string" } },
        "body": {}
      },
      "additionalProperties": false
    },
    "check": {
      "type": "object",
      "required": ["request"],
      "properties": {
        "request": { "$ref": "#/$defs/request" },
        "expect": { "$ref": "#/$defs/expect" }
      },
      "additionalProperties": false
    }
  }
}
